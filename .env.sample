# =============================================================================
# LLM 接続先: Anthropic API と Amazon Bedrock のいずれかを使用します。
# claude-agent-sdk が .env の変数を読みます。
# =============================================================================

# --- Anthropic API を使う場合 ---
# 以下を設定し、Bedrock 用の変数は設定しないでください。
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Amazon Bedrock を使う場合 ---
# 以下を有効にし、ANTHROPIC_API_KEY は不要です（Bedrock API キーで認証します）。
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=ap-northeast-1
# AWS_BEARER_TOKEN_BEDROCK=xxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=apac.anthropic.claude-sonnet-4-20250514-v1:0

# --- オプション: レビューエージェント（A2A）の URL ---
# 記事作成エージェントからレビューを依頼する先。未設定時は http://localhost:9999
# A2A_BASE_URL=http://localhost:9999
# レビューエージェントのエージェントカード公開 URL（通常は未設定で可）
# A2A_CARD_URL=http://localhost:9999/
